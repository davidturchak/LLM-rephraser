<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="LLM-Rephraser"
           Manufacturer="David Turchak"
           Version="1.2.46.0"
           UpgradeCode="1E4E9E57-9523-4C82-A7AD-5F36A5EDF05C"
           Compressed="yes"
           InstallerVersion="500"
           Scope="perUser">

    <MajorUpgrade DowngradeErrorMessage="A newer version of LLM-Rephraser is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Icon shown in Add/Remove Programs -->
    <Icon Id="AppIcon" SourceFile="..\rephrase-tool.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/davidturchak/LLM-rephraser" />

    <!-- License file for UI -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!-- UI: install dir dialog set -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- Kill running process before uninstall/upgrade (hidden window) -->
    <CustomAction Id="KillApp" Directory="INSTALLFOLDER"
                  ExeCommand="powershell.exe -WindowStyle Hidden -Command &quot;Stop-Process -Name 'LLM-Rephraser' -Force -ErrorAction SilentlyContinue&quot;"
                  Impersonate="yes" Return="ignore" />

    <!-- Launch app after install -->
    <CustomAction Id="LaunchApp" FileRef="LLMRephraser.exe" ExeCommand=""
                  Impersonate="yes" Return="asyncNoWait" />

    <InstallExecuteSequence>
      <Custom Action="KillApp" Before="InstallValidate"
              Condition="REMOVE OR WIX_UPGRADE_DETECTED" />
      <Custom Action="LaunchApp" After="InstallFinalize"
              Condition="NOT REMOVE" />
    </InstallExecuteSequence>

    <!-- Directory structure -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="LLM-Rephraser" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuDir" Name="LLM-Rephraser" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <!-- Main application files -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Component Id="MainExe" Guid="61FDE17C-8EDB-488C-B770-C48D564B4351">
        <File Id="LLMRephraser.exe"
              Name="LLM-Rephraser.exe"
              Source="..\bin\Release\net10.0-windows\win-x64\publish\LLM-Rephraser.exe"
              KeyPath="yes" />
      </Component>
      <Component Id="AppIconFile" Guid="A3B7D1E2-4F89-4C6A-9D12-7E5F8A3B6C01">
        <File Id="RephraseToolIco"
              Name="rephrase-tool.ico"
              Source="..\rephrase-tool.ico"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Start Menu shortcut -->
    <ComponentGroup Id="StartMenuShortcuts" Directory="StartMenuDir">
      <Component Id="StartMenuShortcut" Guid="C0EF0E61-167E-4296-94D9-16367B6C91F2">
        <Shortcut Id="StartMenuLink"
                  Name="LLM-Rephraser"
                  Target="[INSTALLFOLDER]LLM-Rephraser.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
        <RemoveFolder Id="RemoveStartMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\LLM-Rephraser"
                       Name="StartMenu" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Desktop shortcut -->
    <ComponentGroup Id="DesktopShortcuts" Directory="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="E6D22AC6-CAD4-4F02-974F-1A6E3A965D4B">
        <Shortcut Id="DesktopLink"
                  Name="LLM-Rephraser"
                  Target="[INSTALLFOLDER]LLM-Rephraser.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
        <RegistryValue Root="HKCU" Key="Software\LLM-Rephraser"
                       Name="Desktop" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Features -->
    <Feature Id="MainApp" Title="LLM-Rephraser" Level="1" AllowAbsent="no">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="StartMenuShortcuts" />
      <ComponentGroupRef Id="DesktopShortcuts" />
    </Feature>

  </Package>
</Wix>
